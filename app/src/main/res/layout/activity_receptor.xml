<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo o icono -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RECEPTOR"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"/>

        <!-- Welcome -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bienvenido, Receptor"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <!-- Address -->
        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tu address:"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <!-- Botón Escanear Pago -->
        <Button
            android:id="@+id/btnEscanearPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Escanear Pago (QR 1)"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Botón Completar Pago -->
        <Button
            android:id="@+id/btnCompletarPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Completar Pago (QR 3)"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>