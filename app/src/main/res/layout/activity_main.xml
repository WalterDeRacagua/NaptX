<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        tools:context=".ui.main.MainActivity">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/logo_koala"
            android:contentDescription="@string/logo_de_la_aplicaci_n"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_margin="24dp"/>

        <!-- Título (NaptX transacción siesta) -->
        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/naptx"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            app:layout_constraintTop_toBottomOf="@+id/ivLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>

        <!-- Subtitulo -->
        <TextView
            android:id="@+id/tvSubtitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/selecciona_tu_rol"
            android:textSize="16sp"
            android:textColor="@color/accent"
            app:layout_constraintTop_toBottomOf="@+id/tvTitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <!-- Rol: Pagador -->
        <Button
            android:id="@+id/btnPagador"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Emisor"
            android:textSize="18sp"
            android:paddingVertical="16dp"
            app:layout_constraintTop_toBottomOf="@+id/tvSubtitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"/>

        <!-- Rol: Receptor -->
        <Button
            android:id="@+id/btnReceptor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/receptor"
            android:textSize="18sp"
            android:paddingVertical="16dp"
            app:layout_constraintTop_toBottomOf="@+id/btnPagador"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/btnCrearWallet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Crear Wallet"
            android:textSize="18sp"
            android:paddingVertical="16dp"
            style="@style/Widget.Material3.Button"
            app:layout_constraintTop_toBottomOf="@id/btnReceptor"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/btnVerEstado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ver Estado"
            android:textSize="18sp"
            android:paddingVertical="16dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:layout_constraintTop_toBottomOf="@id/btnCrearWallet"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>


        <!-- Separador -->
        <View
            android:id="@+id/viewSeparador"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            app:layout_constraintTop_toBottomOf="@id/btnVerEstado"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"/>

        <!-- Título Tokens -->
        <TextView
            android:id="@+id/tvTituloTokens"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestión de Tokens"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/viewSeparador"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>

        <!-- Botón Comprar Tokens -->
        <Button
            android:id="@+id/btnComprarTokens"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Comprar NPTX"
            android:textSize="18sp"
            android:paddingVertical="16dp"
            android:backgroundTint="@color/accent"
            app:layout_constraintTop_toBottomOf="@id/tvTituloTokens"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"/>

        <!-- Botón Vender Tokens -->
        <Button
            android:id="@+id/btnVenderTokens"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Vender NPTX"
            android:textSize="18sp"
            android:paddingVertical="16dp"
            android:backgroundTint="@color/error"
            app:layout_constraintTop_toBottomOf="@id/btnComprarTokens"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>