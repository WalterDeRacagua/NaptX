<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Consultar Estado Emisor"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="24dp"/>

    <!-- Subtítulo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Introduce una address Ethereum para consultar su estado en el contrato:"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="16dp"/>

    <!-- Campo de texto para la address -->
    <EditText
        android:id="@+id/etAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="0x..."
        android:inputType="text"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <!-- Botón consultar -->
    <Button
        android:id="@+id/btnConsultar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Consultar Estado"
        android:textSize="16sp"
        android:paddingVertical="12dp"
        android:layout_marginBottom="24dp"/>

    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/card_border"
        android:layout_marginBottom="16dp"/>

    <!-- Área de resultados (con scroll) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Presiona 'Consultar Estado' para ver los resultados"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:padding="16dp"
            android:background="@color/card_background"
            android:textColor="@color/text_primary"/>

    </ScrollView>

</LinearLayout>