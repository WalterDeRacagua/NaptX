<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Test KeystoreManager"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <!-- Botones de acción -->
    <Button
        android:id="@+id/btnGenerarClaves"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Generar Claves"
        android:textSize="16sp"
        android:paddingVertical="12dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnObtenerAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Obtener Address"
        android:textSize="16sp"
        android:paddingVertical="12dp"
        android:layout_marginBottom="12dp"
        android:enabled="false"/>

    <Button
        android:id="@+id/btnFirmarMensaje"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Firmar Mensaje"
        android:textSize="16sp"
        android:paddingVertical="12dp"
        android:layout_marginBottom="24dp"
        android:enabled="false"/>

    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/card_border"
        android:layout_marginBottom="16dp"/>

    <!-- Área de resultados (con scroll) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Presiona 'Generar Claves' para empezar\n\n"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:padding="16dp"
            android:background="@color/card_background"
            android:textColor="@color/text_primary"/>

    </ScrollView>

</LinearLayout>