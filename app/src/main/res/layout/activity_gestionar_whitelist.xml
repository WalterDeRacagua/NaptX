<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Receptores Autorizados"
        android:textSize="24sp"
        android:textColor="@color/text_on_dark"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:layout_marginTop="32dp"
        />

    <!-- Botón añadir -->
    <Button
        android:id="@+id/btnAnadirReceptor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ Añadir Receptor"
        android:textSize="16sp"
        android:textColor="@color/text_on_dark"
        android:background="@drawable/button_primary"
        android:layout_margin="16dp"/>

    <TextView
        android:id="@+id/tvVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No hay receptores autorizados\n\nPulsa el botón para añadir uno"
        android:textSize="14sp"
        android:textColor="@color/accent"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <ListView
        android:id="@+id/lvReceptores"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:divider="@color/text_hint"
        android:dividerHeight="1dp"/>

</LinearLayout>