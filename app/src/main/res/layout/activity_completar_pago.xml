<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Completar Pago"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"/>

        <!-- Estado -->
        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Escanea el QR 3 del emisor"
            android:textSize="16sp"
            android:gravity="center"
            android:padding="16dp"
            android:layout_marginBottom="24dp"/>

        <!-- Botón escanear -->
        <Button
            android:id="@+id/btnEscanear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Escanear QR 3 del emisor"
            android:textSize="18sp"
            android:padding="16dp"
            android:layout_marginBottom="24dp"/>

        <!-- Datos del pago -->
        <TextView
            android:id="@+id/tvDatos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:id="@+id/layoutQR4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="24dp"
            android:background="#E8F5E9"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡PAGO COMPLETADO!"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QR 4 - HashFinal"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <ImageView
                android:id="@+id/ivQR4"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:contentDescription="QR Code HashFinal"
                android:scaleType="fitCenter"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Muestra este QR al emisor\npara que actualice su hash"
                android:textSize="14sp"
                android:textAlignment="center"
                android:textColor="#555555"/>
        </LinearLayout>

        <!-- Botón nuevo escaneo -->
        <Button
            android:id="@+id/btnNuevoEscaneo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completar Otro Pago"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>